digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.65, nodesep=0.48];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=LR;
  splines=ortho;
  node [shape=box, style="rounded,filled", width=2.2, height=0.55];

  subgraph cluster_core {
    label="Core Runtime · contracts and commit boundary"; color="#dfe5ee"; style="rounded,dashed"; fontsize=18; fontcolor="#607086";
    Entity [label="Entity / Owner\nEntityId · versions", fillcolor="#edf5ff", color="#7aa7df"];
    Stat [label="Stat System\npure GetValue + Modifier plans", fillcolor="#eaf0ff", color="#8292f7"];
    Condition [label="Condition / Context\nread-only predicates", fillcolor="#fff7e6", color="#e0ad4e"];
    Tag [label="Tag System\nfire · melee · boss · skill", fillcolor="#f3eefc", color="#ab8fe0"];
    Commit [label="RuntimeCommitter\nversions · invariants\nstate + outbox atomic", fillcolor="#eefbf6", color="#61b99a"];
    Event [label="Committed Facts Bus\nSkillCommitted · DamageCommitted\nStatChanged · StatusApplied", fillcolor="#e9fbff", color="#54b7cf"];
    Reaction [label="ReactionQueue\npriority · stable key · budget", fillcolor="#f3eefc", color="#ab8fe0"];
  }
  subgraph cluster_bridge {
    label="Effect Bridge · public execution and composition planning"; color="#dfe5ee"; style="rounded,dashed"; fontsize=18; fontcolor="#607086";
    Effect [label="Effect System\npublic Execute(Operation | Bundle)\npublic Prepare(Bundle) plan", fillcolor="#fff0f3", color="#e07b91", penwidth=2.2];
    Combat [label="Combat Resolution\npure DamageResult", fillcolor="#fff0f3", color="#e07b91"];
    Status [label="Status System\nstatus / tick mutation plan", fillcolor="#e9fbff", color="#54b7cf"];
  }
  subgraph cluster_game {
    label="Game layer · commands and policies"; color="#dfe5ee"; style="rounded,dashed"; fontsize=18; fontcolor="#607086";
    Skill [label="Skill / Action\ncost · cooldown · timeline", fillcolor="#f7f9fc"];
    Equipment [label="Equipment / Item\nmodifier + reaction definitions", fillcolor="#f7f9fc"];
    Progression [label="Progression\nbase stat mutation", fillcolor="#f7f9fc"];
    Reward [label="Reward / Roguelite\neffect + modifier definitions", fillcolor="#f7f9fc"];
  }
  Debug [label="Observation / Debug\nBreakdown · CombatLog · UI", fillcolor="#f0f3f9", color="#99a8bd"];

  Entity -> Stat [label="owns snapshot"];
  Stat -> Effect [label="GetValue(owner, stat, ctx)", style=dashed];
  Condition -> Effect [label="validate", style=dashed];
  Tag -> Effect [label="classify", style=dashed];
  Skill -> Effect [label="IEffectPlanner.Prepare(bundle, context)"];
  Effect -> Combat [label="DamageRequest"];
  Combat -> Effect [label="DamageResult", style=dashed];
  Skill -> Commit [label="cost/cooldown plan"];
  Effect -> Commit [label="EffectBundlePlan"];
  Status -> Commit [label="status/tick plan"];
  Equipment -> Stat [label="modifier plan"];
  Progression -> Stat [label="base mutation plan"];
  Reward -> Effect [label="definitions"];
  Reward -> Stat [label="modifier plan"];
  Stat -> Commit [label="stat/resource mutation"];
  Commit -> Event [label="dispatch after commit"];
  Event -> Reaction [label="state-changing follow-up"];
  Reaction -> Effect [label="new Effect command"];
  Reaction -> Status [label="ApplyStatus command"];
  Event -> Debug [label="observe"];
  Stat -> Debug [label="DebugBreakdown", style=dashed];
  Combat -> Debug [label="calculation trace", style=dashed];
}
