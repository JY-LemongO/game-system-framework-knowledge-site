digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.70, nodesep=0.50];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=LR; splines=ortho;
  subgraph cluster_def { label="Definition Data"; color="#dbe3ef"; style="rounded";
    DamageTypeDefinition [label="DamageTypeDefinition
- id
- tags
- defaultResistanceStat"];
    CombatFormulaDefinition [label="CombatFormulaDefinition
- order
- roundingPolicy
- minDamage
- clampRule"];
    ResistanceTable [label="ResistanceTable
- type
- cap
- penetrationRule"];
  }
  subgraph cluster_runtime { label="Runtime Data"; color="#dbe3ef"; style="rounded";
    DamageRequest [label="DamageRequest
- AttackerId
- DefenderId
- Source: SourceRef
- FormulaId
- DamageType
- BaseValue
- CoefficientBps
- Tags
- Seed"];
    CombatContext [label="CombatContext
- position
- tags
- randomStream"];
    DamageResult [label="DamageResult
- Hit
- Critical
- RawDamage
- ResolvedDamage
- ShieldAbsorbed
- FinalHpDamage"];
    CombatLog [label="CombatLog
- formulaSteps
- statReads
- eventIds"];
  }
  DamageTypeDefinition -> DamageRequest [label="type ref"];
  CombatFormulaDefinition -> DamageResult [label="calculation policy"];
  ResistanceTable -> DamageResult [label="mitigation policy"];
  DamageRequest -> CombatContext -> DamageResult -> CombatLog;
}
