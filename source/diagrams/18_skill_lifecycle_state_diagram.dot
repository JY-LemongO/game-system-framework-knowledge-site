digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.55, nodesep=0.50];
  node [fontname="Noto Sans CJK KR", shape=ellipse, style="filled", color="#8fa3c2", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.16,0.10"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB;

  Start [shape=point, width=0.20, label=""];
  Ready [fillcolor="#eefbf6", color="#61b99a", label="Ready\n사용 가능"];
  Queued [fillcolor="#eaf0ff", color="#8292f7", label="Queued\n입력 대기"];
  Validating [fillcolor="#f3eefc", color="#ab8fe0", label="Validating\n비용 · 쿨다운 · 대상"];
  Casting [fillcolor="#fff7e6", color="#e0ad4e", label="Casting\nwindup / cast"];
  HitFrame [fillcolor="#fff0f3", color="#e07b91", label="Hit Frame\nEffectBundle 실행"];
  Recovery [fillcolor="#e9fbff", color="#54b7cf", label="Recovery\n후딜"];
  Cooldown [fillcolor="#f0f3f9", color="#99a8bd", label="Cooldown\n재사용 대기"];
  Failed [fillcolor="#fff0f3", color="#e07b91", label="Failed\n검증 실패"];
  Interrupted [fillcolor="#fff0f3", color="#e07b91", label="Interrupted\n중단 / 환불 정책"];
  Cancelled [fillcolor="#f0f3f9", color="#99a8bd", label="Cancelled\n캔슬 윈도우"];

  Start -> Ready;
  Ready -> Queued [label="input / AI request"];
  Queued -> Validating [label="resolve request"];
  Validating -> Casting [label="valid"];
  Validating -> Failed [label="invalid"];
  Failed -> Ready [label="no cost", style=dashed];
  Casting -> HitFrame [label="marker reached"];
  Casting -> Interrupted [label="stun / silence / hit"];
  Casting -> Cancelled [label="cancel window"];
  Interrupted -> Cooldown [label="failure cooldown?", style=dashed];
  Cancelled -> Ready [label="refund / no cooldown", style=dashed];
  HitFrame -> Recovery [label="EffectResult built"];
  Recovery -> Cooldown [label="finish"];
  Cooldown -> Ready [label="time elapsed / charge restored"];
}
