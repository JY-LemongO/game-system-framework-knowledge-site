digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.34, ranksep=0.74, nodesep=0.48, splines=ortho];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#b8c5d8", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.18,0.13"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", arrowsize=0.75, penwidth=1.35];
  rankdir=LR;

  Input [shape=component, fillcolor="#f7f8fb", label="Input Adapters\nPlayer · AI · Network"];
  Storage [shape=component, fillcolor="#f7f8fb", label="Persistence Adapters\nDB Transaction · Durable Outbox"];
  Engine [shape=component, fillcolor="#f7f8fb", label="Engine Adapters\nAnimation · Physics · Resources"];
  Telemetry [shape=component, fillcolor="#f7f8fb", label="Observation Adapters\nUI · Audio · Trace · Analytics"];

  Contracts [fillcolor="#eefbf6", label="Contract Boundary\nCommandEnvelope · DomainEvent\nVersioned Document"];
  Kernel [shape=component, fillcolor="#eaf0ff", penwidth=2.0, label="Runtime Kernel\nResolve · Commit · Reaction\nStatus Tick · Cache · Migration"];
  Replay [shape=note, fillcolor="#fff7e6", label="Replay Fixture\nInput + Versions + Seed\nExpected Hash"];

  Input -> Contracts [label="command"];
  Contracts -> Kernel [label="validated intent"];
  Kernel -> Storage [label="atomic plan / outbox"];
  Storage -> Kernel [style=dashed, label="snapshot / versions"];
  Kernel -> Engine [label="committed result"];
  Kernel -> Telemetry [label="observation events"];
  Replay -> Kernel [label="deterministic test"];
  Kernel -> Replay [style=dashed, label="trace + hash"];
}
