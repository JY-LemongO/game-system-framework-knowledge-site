
digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.70, nodesep=0.50];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=LR;
  splines=ortho;

  node [width=2.15, height=0.55];
  subgraph cluster_contract {
    label="공통 계약: 모든 시스템이 공유하는 언어"; style="rounded,dashed"; color="#dfe5ee"; fontcolor="#607086"; fontsize=18;
    EntityRegistry [label="EntityRegistry
EntityId / EntityRef", fillcolor="#eaf0ff", color="#8292f7"];
    TagService [label="TagService
TagSet / Tag Query", fillcolor="#f3eefc", color="#ab8fe0"];
    SourceTracker [label="SourceTracker
SourceRef / definition / instance", fillcolor="#fff7e6", color="#e0ad4e"];
    ContextFactory [label="GameContextFactory
actor · target · seed · time", fillcolor="#eefbf6", color="#61b99a"];
  }
  subgraph cluster_runtime {
    label="런타임 서비스: 실행·재현·추적"; style="rounded,dashed"; color="#dfe5ee"; fontcolor="#607086"; fontsize=18;
    EventBus [label="EventBus
committed facts only", fillcolor="#fff0f3", color="#e07b91"];
    RuntimeCommitter [label="RuntimeCommitter
versions · invariants
state + outbox atomic", fillcolor="#eefbf6", color="#61b99a"];
    DurableOutbox [label="Durable Outbox
committed event records", fillcolor="#e9fbff", color="#54b7cf"];
    ReactionQueue [label="ReactionQueue
priority · stable key
depth / budget", fillcolor="#f3eefc", color="#ab8fe0"];
    TimeService [label="TimeService
tick / duration / cooldown", fillcolor="#e9fbff", color="#54b7cf"];
    RandomService [label="RandomStream
seeded deterministic random", fillcolor="#f0f3f9", color="#99a8bd"];
    DataRegistry [label="DataRegistry
Definition lookup", fillcolor="#f7f9fc", color="#bac7db"];
    DebugTrace [label="DebugTrace
correlationId / breakdown", fillcolor="#f0f3f9", color="#99a8bd"];
  }
  subgraph cluster_consumers {
    label="소비 시스템"; style="rounded,dashed"; color="#dfe5ee"; fontcolor="#607086"; fontsize=18;
    Stat [label="Stat System
값 계산", fillcolor="#eaf0ff", color="#8292f7"];
    Effect [label="Effect System
결과 실행", fillcolor="#fff0f3", color="#e07b91"];
    Skill [label="Skill / Action
행동 실행", fillcolor="#fff7e6", color="#e0ad4e"];
    Combat [label="Combat
피해 해석", fillcolor="#eefbf6", color="#61b99a"];
    Status [label="Status
지속 상태", fillcolor="#f3eefc", color="#ab8fe0"];
    Equipment [label="Equipment
Modifier source", fillcolor="#f7f9fc", color="#bac7db"];
  }
  EntityRegistry -> ContextFactory [label="actor/target resolve"];
  TagService -> ContextFactory [label="tags"];
  SourceTracker -> ContextFactory [label="source"];
  ContextFactory -> RuntimeCommitter [label="identity / correlation"];
  TimeService -> Skill [label="cooldown"];
  TimeService -> Status [label="duration/tick"];
  RandomService -> Skill [label="request seed"];
  RandomService -> Combat [label="hit/crit"];
  DataRegistry -> Stat [label="definitions"];
  DataRegistry -> Effect [label="definitions"];
  DataRegistry -> Skill [label="definitions"];
  Skill -> RuntimeCommitter [label="cost/cooldown plan"];
  Effect -> RuntimeCommitter [label="effect plan"];
  Combat -> RuntimeCommitter [label="DamageResult plan"];
  Status -> RuntimeCommitter [label="status/tick plan"];
  RuntimeCommitter -> DurableOutbox [label="same transaction"];
  DurableOutbox -> EventBus [label="dispatch committed facts"];
  EventBus -> ReactionQueue [label="state-changing reactions"];
  ReactionQueue -> Effect [label="new command"];
  ReactionQueue -> Status [label="new command"];
  EventBus -> DebugTrace [label="observation"];
  Stat -> DebugTrace [label="breakdown"];
  Effect -> DebugTrace [label="effect log"];
  Combat -> DebugTrace [label="damage log"];
}
