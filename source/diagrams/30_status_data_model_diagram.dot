digraph G {
  graph [fontname="Noto Sans KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.82, nodesep=0.66];
  node [fontname="Noto Sans KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.18,0.12"];
  edge [fontname="Noto Sans KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB; splines=polyline;
  subgraph cluster_def { label="Status Definition Data"; color="#dbe3ef"; style="rounded";
    StatusDefinition [label="StatusDefinition
- id
- displayName
- tags"];
    DurationRule [label="DurationRule
- durationTicks
- clockDomain
- refreshPolicy"];
    StackingRule [label="StackingRule
- type
- maxStacks
- onReapply"];
    TickRule [label="TickRule
- intervalTicks
- startPolicy
- MaxCatchUpTicks"];
    ModifierTemplate [label="ModifierTemplate
- stat
- operation
- value"];
    PeriodicEffectRef [label="PeriodicEffectRef
- effectId
- timing"];
  }
  subgraph cluster_runtime { label="Status Runtime State"; color="#dbe3ef"; style="rounded";
    StatusInstance [label="StatusInstance
- instanceId
- target
- Source: SourceRef
- modifierSourceRef=SourceRef.Status
  (definitionId, instanceId)"];
    StackState [label="StackState
- count
- contributors"];
    DurationState [label="DurationState
- startTick
- expiresAtTick
- clockDomain"];
    TickState [label="TickState
- nextTickAt
- elapsedTicks"];
    SnapshotState [label="SnapshotState
- capturedStats?
- seed"];
  }
  StatusDefinition -> DurationRule;
  StatusDefinition -> StackingRule;
  StatusDefinition -> TickRule;
  StatusDefinition -> ModifierTemplate;
  StatusDefinition -> PeriodicEffectRef;
  Instantiation [label="Instantiate\nruntime state", fillcolor="#eefbf6", color="#61b99a", margin="0.12,0.08"];

  StatusDefinition -> Instantiation [arrowhead=none];
  Instantiation -> StatusInstance;
  StatusInstance -> StackState;
  StatusInstance -> DurationState;
  StatusInstance -> TickState;
  StatusInstance -> SnapshotState;
}
