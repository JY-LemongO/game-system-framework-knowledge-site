digraph ModifierStateDiagram {
	graph [bgcolor=white fontname="Noto Sans KR" fontsize=18 label="UML State Diagram - StatModifier Lifecycle" labelloc=t newrank=true nodesep=1.0 outputorder=edgesfirst rankdir=LR ranksep=1.05 splines=spline]
	node [color="#425466" fontname="Noto Sans KR" fontsize=11 shape=box style="rounded,filled"]
	edge [arrowsize=0.8 color="#425466" fontname="Noto Sans KR" fontsize=9 penwidth=1.2]
	created [label="Created
데이터에서 생성됨" fillcolor="#FFF3CD"]
	pending [label="Pending
조건/대상 검증 대기" fillcolor="#E8F0FE"]
	active [label="Active
계산 대상에 포함" fillcolor="#DFF7E4"]
	suspended [label="Suspended
조건 불충족, 보존됨" fillcolor="#F3E5F5"]
	stacked [label="Stacked / Refreshed
중첩 규칙 적용" fillcolor="#E0F7FA"]
	expired [label="Expired
시간/횟수 종료" fillcolor="#FCE8E6"]
	removed [label="Removed
source 제거/장비 해제" fillcolor="#FCE8E6"]
	serialized [label="Serialized
저장 가능한 상태" fillcolor="#F1F8E9"]
	final [label=Final fillcolor="#111827" fontcolor=white shape=doublecircle]
	{ rank=same; suspended; active; stacked; serialized }
	{ rank=same; expired; removed }
	created:e -> pending:w [label="Attach(owner)" color="#5B6F8F"]
	pending:e -> active:w [label="target valid and condition true" color="#3D8B6D"]
	pending:e -> removed:w [label="reject invalid target" color="#B45D69"]
	active:n -> suspended:s [headlabel="condition becomes false" labelangle=28 labeldistance=2.4 color="#7257A6" fontcolor="#7257A6"]
	suspended:e -> active:e [taillabel="condition becomes true" labelangle=-28 labeldistance=2.4 color="#7257A6" fontcolor="#7257A6" constraint=false style=dashed]
	active:s -> stacked:n [headlabel="same source/id reapplied" labelangle=24 labeldistance=2.6 color="#397B8C" fontcolor="#397B8C"]
	stacked:w -> active:w [taillabel="merge / refresh / recalculate" labelangle=-24 labeldistance=2.6 color="#397B8C" fontcolor="#397B8C" constraint=false style=dashed]
	active:se -> expired:w [label="duration or uses exhausted" color="#B45D69"]
	active:e -> removed:w [label="RemoveBySource / Dispel" color="#B45D69"]
	active:s -> serialized:n [headlabel="save runtime snapshot" labelangle=24 labeldistance=2.4 color="#5B7F4A" fontcolor="#5B7F4A"]
	serialized:e -> active:e [taillabel="restore snapshot" labelangle=-24 labeldistance=2.4 color="#5B7F4A" fontcolor="#5B7F4A" constraint=false style=dashed]
	expired:e -> final:w [color="#425466"]
	removed:e -> final:w [color="#425466"]
}
