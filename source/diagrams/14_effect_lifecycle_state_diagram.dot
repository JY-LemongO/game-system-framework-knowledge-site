
digraph G {

  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.65, nodesep=0.48];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];

  rankdir=LR;
  splines=ortho;
  node [shape=box, style="rounded,filled", width=1.75, height=0.5];
  Defined [label="Defined
데이터에 존재", fillcolor="#fff7e6", color="#e0ad4e"];
  Registered [label="Registered
Registry 로드·검증", fillcolor="#eaf0ff", color="#8292f7"];
  Requested [label="Requested
실행 요청 생성", fillcolor="#eaf0ff", color="#8292f7"];
  Validating [label="Validating
조건·비용·상태 검사", fillcolor="#f3eefc", color="#ab8fe0"];
  ResolvingTargets [label="Resolving Targets
대상 선택", fillcolor="#f3eefc", color="#ab8fe0"];
  ResolvingValues [label="Resolving Values
스탯·수식 계산", fillcolor="#eefbf6", color="#61b99a"];
  Applying [label="Applying
결과 적용", fillcolor="#fff0f3", color="#e07b91"];
  Completed [label="Completed
EffectResult 반환", fillcolor="#eefbf6", color="#61b99a"];
  Scheduled [label="Scheduled
지연/반복 대기", fillcolor="#f0f3f9", color="#99a8bd"];
  WaitingTrigger [label="Waiting Trigger
이벤트 반응 대기", fillcolor="#f0f3f9", color="#99a8bd"];
  Cancelled [label="Cancelled
취소됨", fillcolor="#fff0f3", color="#e07b91"];
  Failed [label="Failed
검증/대상 없음", fillcolor="#fff0f3", color="#e07b91"];
  Logged [label="Logged
EffectLog 저장", fillcolor="#f3eefc", color="#ab8fe0"];

  Defined -> Registered [label="load"];
  Registered -> Requested [label="skill/status/event"];
  Requested -> Validating;
  Validating -> Failed [label="조건 실패"];
  Validating -> ResolvingTargets [label="통과"];
  ResolvingTargets -> Failed [label="대상 없음"];
  ResolvingTargets -> ResolvingValues;
  ResolvingValues -> Applying;
  Applying -> Completed;
  Requested -> Scheduled [label="delay/repeat"];
  Scheduled -> Requested [label="timer"];
  Registered -> WaitingTrigger [label="event reaction"];
  WaitingTrigger -> Requested [label="trigger"];
  Scheduled -> Cancelled [label="dispel/source remove"];
  Applying -> Cancelled [label="interrupt"];
  Completed -> Logged;
  Failed -> Logged;
  Cancelled -> Logged;
}
