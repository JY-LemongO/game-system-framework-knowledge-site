digraph G {
  graph [fontname="Noto Sans KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.74, nodesep=0.72, ordering=out];
  node [fontname="Noto Sans KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.18,0.12"];
  edge [fontname="Noto Sans KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB;
  splines=polyline;

  start [shape=circle, width=.28, label="", fillcolor="#182033", color="#182033"];
  due [label="Simulation tick reached"];
  active [shape=diamond, label="StatusInstance still active?"];
  cap [shape=diamond, label="catch-up count below\nMaxCatchUpTicks?"];
  capExpired [shape=diamond, label="ExpiresAt <= now?"];
  limitedPlan [label="Build removal plan\nreason = CatchUpLimited\ntrace dropped ticks"];
  defer [label="Leave overdue tick\nfor next advance\ntrace deferred count\nno domain mutation"];
  context [label="Build EffectContext\nSourceRef + StatusInstanceId\nTargetId = owner · stack included"];
  resolve [label="DamageEffect →\nICombatResolver.Resolve\npure DamageResult\nno mutation / event", fillcolor="#eaf0ff", color="#8292f7"];
  tickPlan [label="Build one Tick CommitPlan\nShield/HP + NextTickAt or removal\nDamage/Status outbox facts", fillcolor="#fff7e6", color="#e0ad4e"];
  commit [label="RuntimeCommitter.Commit once\nversions · invariants\nstate + outbox", fillcolor="#eefbf6", color="#61b99a"];
  facts [label="Committed facts dispatch\nDamageCommitted · StatusTicked\nStatusExpired when terminal", fillcolor="#e9fbff", color="#54b7cf"];
  remains [shape=diamond, label="Instance remains active?"];
  backlog [shape=diamond, label="overdue tick remains?"];
  schedule [label="Keep next tick scheduled"];
  removePlan [label="Build normal expiry\nremoval plan\nmodifiers + instance\n+ StatusExpired outbox"];
  removalCommit [label="RuntimeCommitter.Commit\nstatus removal\n+ outbox atomic", fillcolor="#eefbf6", color="#61b99a"];
  reject [label="Commit rejected\nno HP / Shield / time mutation\nno event", fillcolor="#fff0f3", color="#e07b91"];
  continueCatchUp [label="Continue catch-up\nnext overdue tick", fillcolor="#f3eefc", color="#ab8fe0"];
  end [shape=doublecircle, width=.32, label="", fillcolor="#ffffff", color="#182033"];

  start -> due -> active;
  active -> removePlan [label="no"];
  removePlan -> removalCommit -> facts;
  active -> cap [label="yes"];
  cap -> capExpired [label="no"];
  capExpired -> limitedPlan [label="yes"];
  limitedPlan -> removalCommit;
  capExpired -> defer [label="no"];
  defer -> end;
  cap -> context [label="yes"];
  context -> resolve -> tickPlan -> commit;
  commit -> reject [label="fail", style=dashed, color="#dc2626", fontcolor="#dc2626"];
  reject -> end;
  commit -> facts [label="success"];
  facts -> remains;
  remains -> end [label="no"];
  remains -> backlog [label="yes"];
  backlog -> continueCatchUp [label="yes"];
  continueCatchUp:e -> cap:e [style=dashed, color="#8292a8", constraint=false];
  backlog -> schedule [label="no"];
  schedule -> end;
}
