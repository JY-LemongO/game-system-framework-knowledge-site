digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.78, nodesep=0.42, newrank=true, ordering=out];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB;
  splines=polyline;
  node [shape=box, style="rounded,filled", width=2.05, height=0.52];

  FireballSkill [label="SkillDefinition\nskill.fireball", fillcolor="#eaf0ff", color="#8292f7"];
  Cost [label="CostMutation\nMana 20", fillcolor="#f7f9fc"];
  Cooldown [label="CooldownMutation\nready tick 18300", fillcolor="#f7f9fc"];
  Targeting [label="Targeting\nexplicit single target\nentity.target", fillcolor="#f7f9fc"];
  Bundle [label="EffectBundle\nCommitThenReact", fillcolor="#fff7e6", color="#e0ad4e"];
  DamageEffect [label="DamageEffect\nbase 24 + spellPower 120 × 1.2", fillcolor="#fff0f3", color="#e07b91"];
  Combat [label="CombatResolver (pure)\ncritical 252 → resist 202\nshield 40 → HP 162", fillcolor="#eefbf6", color="#61b99a"];
  Commit [label="RuntimeCommitter\nMana + cooldown + Shield/HP\nstate + ordered outbox\natomic", fillcolor="#eefbf6", color="#61b99a"];
  SkillFact [label="SkillCommitted\noutbox #1", fillcolor="#e9fbff", color="#54b7cf"];
  DamageFact [label="DamageCommitted\noutbox #2", fillcolor="#e9fbff", color="#54b7cf"];
  Queue [label="ReactionQueue\napply-burn command", fillcolor="#f3eefc", color="#ab8fe0"];
  Burn [label="ApplyStatusRequest\nstatus.burn · duration 6\ntick interval 2", fillcolor="#fff0f3", color="#e07b91"];
  Status [label="StatusSystem commit\nStatusApplied · +2/+4/+6 ticks", fillcolor="#eefbf6", color="#61b99a"];
  Observe [label="Observation\nUI · CombatLog · DebugTrace", fillcolor="#f0f3f9", color="#99a8bd"];

  // Prepare, resolve, commit, and reaction tiers keep the flow readable inline.
  { rank=same; Cost; Targeting; Bundle; Cooldown; }
  { rank=same; DamageEffect; Combat; }
  { rank=same; DamageFact; Queue; Burn; Status; }

  FireballSkill -> Cost;
  FireballSkill -> Cooldown;
  FireballSkill -> Targeting;
  FireballSkill -> Bundle;
  Bundle -> DamageEffect [label="primary"];
  Targeting -> DamageEffect [label="target"];
  DamageEffect -> Combat [label="DamageRequest"];
  Cost -> Commit [label="plan"];
  Cooldown -> Commit [label="plan"];
  Combat -> Commit [label="DamageResult"];
  Commit -> SkillFact [label="expose ordered outbox"];
  SkillFact -> DamageFact [label="#1 → #2"];
  DamageFact -> Queue;
  Queue -> Burn;
  Burn -> Status;
  DamageFact -> Observe [style=dashed, label="damage fact"];
  Status -> Observe [style=dashed, label="status facts"];
}
