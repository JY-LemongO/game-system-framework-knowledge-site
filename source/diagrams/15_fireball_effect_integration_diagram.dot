
digraph G {

  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.65, nodesep=0.48];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];

  rankdir=LR;
  splines=ortho;
  node [shape=box, style="rounded,filled", width=2.0, height=0.52];
  FireballSkill [label="SkillDefinition
Fireball", fillcolor="#eaf0ff", color="#8292f7"];
  Cost [label="Cost
Mana 30", fillcolor="#f7f9fc"];
  Targeting [label="Targeting
Circle Area r=4", fillcolor="#f7f9fc"];
  Bundle [label="EffectBundle
Sequential", fillcolor="#fff7e6", color="#e0ad4e"];
  DamageEffect [label="DamageEffect
Fire base 40 + spellPower×1.2", fillcolor="#fff0f3", color="#e07b91"];
  BurnEffect [label="ApplyStatusEffect
Burn 5 sec", fillcolor="#fff0f3", color="#e07b91"];
  Stat [label="Stat System
spell_power, fire_bonus, resistance", fillcolor="#eefbf6", color="#61b99a"];
  Combat [label="Combat Resolver
defense/resistance/crit", fillcolor="#eefbf6", color="#61b99a"];
  Status [label="Status Controller
Burn Instance + Tick", fillcolor="#eefbf6", color="#61b99a"];
  Event [label="Event Bus
SkillUsed, DamageDealt, StatusApplied", fillcolor="#f3eefc", color="#ab8fe0"];
  Debug [label="Debug Logs
EffectLog + DamageBreakdown", fillcolor="#f0f3f9", color="#99a8bd"];

  FireballSkill -> Cost;
  FireballSkill -> Targeting;
  FireballSkill -> Bundle;
  Bundle -> DamageEffect [label="1"];
  Bundle -> BurnEffect [label="2"];
  DamageEffect -> Stat [label="value lookup"];
  DamageEffect -> Combat [label="DamageRequest"];
  BurnEffect -> Status [label="create status"];
  Cost -> Stat [label="modify mana"];
  Combat -> Event;
  Status -> Event;
  Event -> Debug;
  Combat -> Debug;
}
