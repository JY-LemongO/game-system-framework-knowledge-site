digraph G {
  graph [fontname="Noto Sans KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.62, nodesep=0.45];
  node [fontname="Noto Sans KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.16,0.10"];
  edge [fontname="Noto Sans KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB;

  start [shape=circle, width=.26, label="", fillcolor="#182033", color="#182033"];
  status [label="StatusSystem\nBuild AddModifier plan\nsource = StatusInstanceId", fillcolor="#eefbf6", color="#5ac39b"];
  commit [label="RuntimeCommitter\nModifierRegistry + dirty state + outbox\natomic commit", fillcolor="#eaf0ff", color="#8292f7"];
  event [label="Committed facts dispatch\nModifierAdded / StatChanged", fillcolor="#f8fafc"];
  query [label="UI / Combat\nGetValue(ownerId, statId, context)", fillcolor="#f4efff", color="#a884e8"];
  pipe [label="CalculationPipeline (pure query)\ncollect · filter · stable sort · calculate", fillcolor="#ffffff"];
  result [label="StatValue + DebugBreakdown\nno domain event", fillcolor="#eefbf6", color="#5ac39b"];
  observe [label="UI refreshes from committed fact\nCombat consumes returned snapshot value", fillcolor="#f4efff", color="#a884e8"];
  end [shape=doublecircle, width=.32, label="", fillcolor="#ffffff", color="#182033"];

  start -> status -> commit -> event -> query -> pipe -> result -> observe -> end;
  commit -> query [style=dashed, label="new snapshot"];
  event -> observe [style=dashed, label="observation"];
}
