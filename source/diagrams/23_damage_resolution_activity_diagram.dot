digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.70, nodesep=0.50];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB; splines=polyline;
  start [shape=circle, width=.28, label="", fillcolor="#182033", color="#182033"];
  validate [label="Validate Target
can receive damage? alive? hittable?"];
  hit [label="Resolve Hit
accuracy, evasion, block, invulnerable"];
  hitFail [shape=diamond, label="Hit failed?"];
  crit [label="Resolve Critical
chance, multiplier, crit resist"];
  base [label="Calculate Base Damage
base + scalingStat × coefficient"];
  off [label="Apply Offensive Modifiers
source tags, damage bonus, critical bonus"];
  def [label="Apply Defensive Modifiers
armor, defense, guard, reduction"];
  resist [label="Apply Resistance / Penetration
resistance cap, pierce, weakness"];
  shield [label="Apply Shield / Absorb
barrier first, redirect, absorb"];
  round [label="Clamp / Round
minimum, maximum, integer policy"];
  result [label="Build DamageResult
finalHpDamage, logs, events"];
  miss [label="Build Miss / Block Result
finalHpDamage = 0"];
  end [shape=doublecircle, width=.32, label="", fillcolor="#ffffff", color="#182033"];
  start -> validate -> hit -> hitFail;
  hitFail -> miss [label="yes"];
  hitFail -> crit [label="no"];
  crit -> base -> off -> def -> resist -> shield -> round -> result -> end;
  miss -> end;
}
