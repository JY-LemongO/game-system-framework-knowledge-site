digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.70, nodesep=0.50];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=LR; splines=ortho;
  Requested [shape=circle, label="Requested", fillcolor="#eefbf6"];
  Rejected [label="Rejected
Invalid / Immune"];
  Applied [label="Applied
create StatusInstance"];
  Active [label="Active
modifiers registered"];
  Ticking [label="Ticking
periodic effects"];
  Refreshed [label="Refreshed
Duration / Stack changed"];
  Expired [label="Expired"];
  Dispelled [label="Dispelled / Cleanse"];
  Removed [shape=doublecircle, label="Removed
remove modifiers
cancel ticks"];
  Requested -> Rejected [label="immune / invalid"];
  Requested -> Applied [label="valid"];
  Applied -> Active [label="register modifiers"];
  Active -> Ticking [label="tick due"];
  Ticking -> Active [label="still active"];
  Active -> Refreshed [label="reapply"];
  Refreshed -> Active;
  Active -> Expired [label="duration <= 0"];
  Active -> Dispelled [label="cleanse"];
  Expired -> Removed;
  Dispelled -> Removed;
  Rejected -> Removed [label="result only"];
}
