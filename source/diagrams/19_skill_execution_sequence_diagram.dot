digraph G {
  graph [fontname="Noto Sans KR", bgcolor="#ffffff", margin=0.12, pad=0.25, ranksep=0.62, nodesep=0.56, splines=polyline];
  node [fontname="Noto Sans KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.18,0.10"];
  edge [fontname="Noto Sans KR", color="#59687e", fontcolor="#46566e", arrowsize=0.8, penwidth=1.3];
  rankdir=TB;

  A [fillcolor="#eaf0ff", color="#8292f7", label="1. Player Input / AI\npublic SkillRequest"];
  B [fillcolor="#f0f3f9", color="#99a8bd", label="2. <<internal project coordinator>>\nSkillExecutionCoordinator.Begin\nDefinition + SkillRuntime 조회"];
  C [fillcolor="#f3eefc", color="#ab8fe0", label="3. <<public>> ISkillRequestValidator.Validate\nSkillDecision accepted / rejected"];
  D [fillcolor="#e9fbff", color="#54b7cf", label="4. <<internal project model>> SkillExecution\nwindup → release marker"];
  E [fillcolor="#eefbf6", color="#61b99a", label="5. <<internal project model>> SkillReleasePlan\n비용 · 쿨다운 mutation 준비"];
  F [fillcolor="#fff7e6", color="#e0ad4e", label="6. <<public>> IEffectPlanner.Prepare\nEffectBundlePlan: operations + reactions"];
  G [fillcolor="#fff0f3", color="#e07b91", label="7. <<internal transaction composition>>\nSkillReleasePlan + EffectBundlePlan"];
  H [fillcolor="#eefbf6", color="#61b99a", label="8. RuntimeCommitter\nstate + outbox 원자적 commit"];
  I [fillcolor="#e9fbff", color="#54b7cf", label="9. Committed facts\nSkillCommitted · DamageCommitted"];
  J [fillcolor="#f3eefc", color="#ab8fe0", label="10. ReactionQueue\nBurn 등 상태 변경 반응 enqueue"];
  K [fillcolor="#f0f3f9", color="#99a8bd", label="11. <<public contract>> SkillResult\nSucceeded · FailureReason · Effects"];

  A -> B -> C -> D -> E -> F -> G -> H -> I -> J -> K;
  C -> K [label="canonical failure reason", style=dashed, color="#dc2626", fontcolor="#dc2626"];
  D -> K [label="Interrupted policy", style=dashed, color="#dc2626", fontcolor="#dc2626"];
  H -> K [label="commit rejected: no mutation/event", style=dashed, color="#dc2626", fontcolor="#dc2626"];
}
