digraph G {
  graph [fontname="Noto Sans CJK KR", bgcolor="#ffffff", margin=0.12, pad=0.34, ranksep=0.72, nodesep=0.48, splines=true];
  node [fontname="Noto Sans CJK KR", shape=box, style="rounded,filled", color="#b8c5d8", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.18,0.13"];
  edge [fontname="Noto Sans CJK KR", color="#59687e", arrowsize=0.75, penwidth=1.35];
  rankdir=LR;

  Input [fillcolor="#f3eefc", label="Input\ncommand · snapshot\nroot seed"];
  Versions [fillcolor="#fff7e6", label="Version Envelope\nruntime · contract · replay\nRNG · numeric · data\ndefinition · formula"];
  Ordering [fillcolor="#eefbf6", label="Stable Semantics\ncanonical JSON · stable IDs\noperation order · tick order"];
  Runtime [shape=component, fillcolor="#eaf0ff", penwidth=2.0, label="Deterministic Runtime\nResolve → Commit → Reaction → Tick"];
  Outputs [fillcolor="#e9fbff", label="Outputs\nfinal state · domain events\ndecisions · trace"];
  Hashes [shape=note, fillcolor="#fff7e6", label="Verification\ntraceHash · replayHash\ngolden fixture"];
  Match [shape=diamond, fillcolor="#eefbf6", label="Hashes and\nstate match?"];
  Pass [fillcolor="#eefbf6", label="Replay accepted"];
  Fail [fillcolor="#fff0f3", label="Regression detected\ninspect first divergent trace stage"];

  Input -> Runtime;
  Versions -> Runtime;
  Ordering -> Runtime;
  Runtime -> Outputs -> Hashes -> Match;
  Match -> Pass [label="yes"];
  Match -> Fail [label="no"];
}
