
digraph G {

  graph [fontname="Noto Sans KR", bgcolor="#ffffff", compound=true, margin=0.12, pad=0.30, ranksep=1.0, nodesep=0.68, newrank=true, outputorder=edgesfirst, splines=polyline];
  node [fontname="Noto Sans KR", shape=box, style="rounded,filled", color="#bac7db", penwidth=1.4, fillcolor="#ffffff", fontcolor="#182033", margin="0.14,0.09"];
  edge [fontname="Noto Sans KR", color="#59687e", fontcolor="#46566e", fontsize=9, arrowsize=0.8, penwidth=1.3];

  rankdir=TB;
  EffectDefinition [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#e07b91">
<TR><TD BGCOLOR="#fff0f3"><B><FONT POINT-SIZE="16">&lt;&lt;content data&gt;&gt; EffectDefinition</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ EffectId: EffectId</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Type: EffectType</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ TargetSelectorId</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ValueExpressionId?</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Conditions: ConditionId[]</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Tags: Tag[]</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Timing: EffectTiming</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ExecutorKey</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ValidateSchema()</FONT></TD></TR>
</TABLE>>];EffectBundle [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#e0ad4e" WIDTH="260">
<TR><TD BGCOLOR="#fff7e6"><B><FONT POINT-SIZE="16">EffectBundle</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BundleId: EntityId</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Effects: EffectOperation[]</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Reactions: ReactionRule[]</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Policy: CommitThenReact</FONT></TD></TR>
</TABLE>>];DefinitionNormalizer [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#8292f7" WIDTH="220">
<TR><TD BGCOLOR="#eaf0ff"><B><FONT POINT-SIZE="16">&lt;&lt;internal stage&gt;&gt; DefinitionNormalizer</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Normalize(definition, context)</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ValidateSchema()</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ResolveTargets()</FONT></TD></TR>
</TABLE>>];EffectOperation [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#61b99a" WIDTH="260">
<TR><TD BGCOLOR="#eefbf6"><B><FONT POINT-SIZE="16">EffectOperation</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">+ OperationId: EntityId</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">DamageEffectOperation</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">ApplyStatusEffectOperation</FONT></TD></TR>
</TABLE>>];EffectContext [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#8292f7">
<TR><TD BGCOLOR="#eaf0ff"><B><FONT POINT-SIZE="16">EffectContext</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ CasterId: EntityId</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ InitialTargetId: EntityId?</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Source: SourceRef</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ RandomSeed</FONT></TD></TR>
</TABLE>>];EffectPipeline [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#8292f7">
<TR><TD BGCOLOR="#eaf0ff"><B><FONT POINT-SIZE="16">EffectPipeline</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Execute(EffectOperation, EffectContext)</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Execute(EffectBundle, EffectContext)</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Prepare(EffectBundle, EffectContext)</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">- BuildMutationAndOutboxPlan()</FONT></TD></TR>
</TABLE>>];IEffectExecutor [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#61b99a" WIDTH="520">
<TR><TD BGCOLOR="#eefbf6"><B><FONT POINT-SIZE="16">&lt;&lt;public interface&gt;&gt; IEffectExecutor</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Execute(EffectOperation, EffectContext): EffectOperationResult</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Execute(EffectBundle, EffectContext): EffectBundleResult</FONT></TD></TR>
</TABLE>>];IEffectOperationExecutor [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#ab8fe0" WIDTH="220">
<TR><TD BGCOLOR="#f3eefc"><B><FONT POINT-SIZE="16">&lt;&lt;internal interface&gt;&gt; IEffectOperationExecutor</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ CanExecute(EffectOperation, EffectContext): bool</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildPlan(EffectOperation, EffectContext): OperationPlan</FONT></TD></TR>
</TABLE>>];DamageEffectExecutor [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#61b99a">
<TR><TD BGCOLOR="#eefbf6"><B><FONT POINT-SIZE="16">DamageEffectExecutor</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildDamageRequest()</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ CallCombatResolver()</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildDamageMutation()</FONT></TD></TR>
</TABLE>>];ApplyStatusExecutor [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#61b99a">
<TR><TD BGCOLOR="#eefbf6"><B><FONT POINT-SIZE="16">ApplyStatusExecutor</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildApplyStatusRequest()</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildReactionCommand()</FONT></TD></TR>
</TABLE>>];ModifyResourceExecutor [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#61b99a">
<TR><TD BGCOLOR="#eefbf6"><B><FONT POINT-SIZE="16">ModifyResourceExecutor</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildResourceMutation()</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ValidateInvariant()</FONT></TD></TR>
</TABLE>>];TargetSelector [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#ab8fe0" WIDTH="220">
<TR><TD BGCOLOR="#f3eefc"><B><FONT POINT-SIZE="16">TargetSelector</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ SelectorType</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Range/Shape/Limit</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Filters</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Select(ctx): TargetSet</FONT></TD></TR>
</TABLE>>];ValueExpression [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#ab8fe0" WIDTH="220">
<TR><TD BGCOLOR="#f3eefc"><B><FONT POINT-SIZE="16">ValueExpression</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BaseValue</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ScalingTerms</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Min/Max</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Evaluate(ctx): decimal</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ BuildBreakdown()</FONT></TD></TR>
</TABLE>>];EffectCondition [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#ab8fe0">
<TR><TD BGCOLOR="#f3eefc"><B><FONT POINT-SIZE="16">EffectCondition</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ ConditionType</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Params</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Evaluate(ctx): bool</FONT></TD></TR>
</TABLE>>];EffectResult [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#99a8bd">
<TR><TD BGCOLOR="#f0f3f9"><B><FONT POINT-SIZE="16">EffectResult</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">+ Succeeded: bool</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">EffectOperationResult: OperationId</FONT></TD></TR><TR><TD ALIGN="LEFT" BALIGN="LEFT"><FONT POINT-SIZE="12">EffectBundleResult: Committed, BundleId, counts</FONT></TD></TR>
</TABLE>>];
  IEffectPlanner [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#54b7cf" WIDTH="480">
<TR><TD BGCOLOR="#e9fbff"><B><FONT POINT-SIZE="16">&lt;&lt;public interface&gt;&gt; IEffectPlanner</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">+ Prepare(EffectBundle, EffectContext): EffectBundlePlan</FONT></TD></TR>
</TABLE>>];
  EffectBundlePlan [shape=plain, label=<
<TABLE BORDER="1" CELLBORDER="0" CELLPADDING="8" CELLSPACING="0" COLOR="#54b7cf">
<TR><TD BGCOLOR="#e9fbff"><B><FONT POINT-SIZE="16">&lt;&lt;public contract&gt;&gt; EffectBundlePlan</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">+ BundleId: EntityId</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">+ PrimaryOperations: EffectOperation[]</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12">+ Reactions: ReactionRule[]</FONT></TD></TR>
</TABLE>>];
  subgraph cluster_definition_model {
    label="Definition Model"; color="#E7D59A"; fontname="Noto Sans KR"; style="rounded,dashed";
    EffectDefinition; TargetSelector; ValueExpression; EffectCondition; DefinitionNormalizer;
    { rank=same; TargetSelector; ValueExpression; EffectCondition; }
  }
  subgraph cluster_public_contracts {
    label="Public Runtime Contracts"; color="#B7DCE5"; fontname="Noto Sans KR"; style="rounded,dashed";
    EffectOperation; EffectBundle; EffectContext; IEffectExecutor; IEffectPlanner; EffectBundlePlan; EffectResult;
    { rank=same; EffectOperation; EffectBundle; EffectContext; }
    { rank=same; IEffectExecutor; IEffectPlanner; }
    { rank=same; EffectBundlePlan; EffectResult; }
  }
  subgraph cluster_runtime_implementation {
    label="Runtime Implementation"; color="#C9B9E8"; fontname="Noto Sans KR"; style="rounded,dashed";
    EffectPipeline; IEffectOperationExecutor; DamageEffectExecutor; ApplyStatusExecutor; ModifyResourceExecutor;
    { rank=same; DamageEffectExecutor; ApplyStatusExecutor; ModifyResourceExecutor; }
  }
  Legend [shape=note, label="Relationship guide\nsolid arrow: data / runtime input\ndashed hollow arrow: interface implementation\npurple arrow: operation dispatch", fontname="Noto Sans KR", fillcolor="#ffffff", color="#99a8bd"];
  EffectBundle:e -> EffectOperation:w [label="contains operations (1..*)" dir=both arrowtail=diamond arrowhead=none color="#8A6D3B"];
  EffectDefinition:s -> TargetSelector:n [label="selects targets" color="#7257A6"];
  EffectDefinition:sw -> ValueExpression:n [label="evaluates optional value" color="#7257A6"];
  EffectDefinition:se -> EffectCondition:n [label="guards with conditions (0..*)" color="#7257A6"];
  EffectDefinition:s -> DefinitionNormalizer:n [label="normalize definition" color="#5B6F8F"];
  DefinitionNormalizer:s -> EffectOperation:n [label="creates runtime EffectOperation" color="#5B6F8F"];
  EffectOperation:s -> IEffectExecutor:nw [color="#3D8B6D"];
  EffectBundle:s -> IEffectExecutor:ne [color="#3D8B6D"];
  EffectBundle:s -> IEffectPlanner:nw [color="#397B8C"];
  EffectContext:sw -> IEffectExecutor:ne [color="#8292A8" style=dashed];
  EffectContext:se -> IEffectPlanner:ne [color="#8292A8" style=dashed];
  EffectPipeline:nw -> IEffectExecutor:s [arrowhead=empty color="#3D8B6D" constraint=false style=dashed];
  EffectPipeline:ne -> IEffectPlanner:s [arrowhead=empty color="#397B8C" constraint=false style=dashed];
  EffectPipeline:s -> IEffectOperationExecutor:n [color="#7257A6"];
  DamageEffectExecutor:s -> IEffectOperationExecutor:nw [arrowhead=empty color="#3D8B6D" style=dashed];
  ApplyStatusExecutor:s -> IEffectOperationExecutor:n [arrowhead=empty color="#3D8B6D" style=dashed];
  ModifyResourceExecutor:s -> IEffectOperationExecutor:ne [arrowhead=empty color="#3D8B6D" style=dashed];
  EffectPipeline:e -> EffectResult:s [color="#8292A8" constraint=false style=dashed];
  IEffectPlanner:s -> EffectBundlePlan:n [label="prepares EffectBundlePlan" color="#397B8C"];
}
