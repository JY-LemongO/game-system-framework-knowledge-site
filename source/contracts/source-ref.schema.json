{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gsf.example/contracts/source-ref.schema.json",
  "title": "GSF Source Reference",
  "description": "A structured reference with a required definition. Skill and status sources require an execution instance; system sources may omit it.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "definitionId"],
  "properties": {
    "kind": {
      "enum": ["skill-execution", "status", "system"]
    },
    "definitionId": {
      "$ref": "#/$defs/namespacedId"
    },
    "instanceId": {
      "$ref": "#/$defs/namespacedId"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "enum": ["skill-execution", "status"] } } },
      "then": { "required": ["instanceId"] }
    }
  ],
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9_-]*)+$"
    }
  }
}
